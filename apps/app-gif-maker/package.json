{
  "name": "app-gif-maker",
  "version": "0.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5177 && electron .\"",
    "electron:build": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@pal/ui": "workspace:*",
    "@pal/utils": "workspace:*",
    "@pal/ipc-types": "workspace:*",
    "@pal/tool-gif-maker": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
