{
	"name": "web-tool-pal",
	"private": true,
	"scripts": {
		"dev:all-in-one": "pnpm --filter app-all-in-one dev",
		"dev:image": "pnpm --filter app-image dev",
		"dev:font-compress": "pnpm --filter app-font-compress dev",
		"electron:all-in-one": "pnpm --filter app-all-in-one electron:dev",
